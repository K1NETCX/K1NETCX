-- [[ 🛰️ PAINEL DE ADMIN ]]
local function buildAdminPanel()
    local sg = lp.PlayerGui:FindFirstChild("K1netic_Admin_Panel") or Instance.new("ScreenGui", lp.PlayerGui)
    sg.Name = "K1netic_Admin_Panel"
    sg.Enabled = false
    sg.ResetOnSpawn = false
    sg:ClearAllChildren()

    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 420, 0, 600)
    frame.Position = UDim2.new(1, -430, 0.5, -300)
    frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    frame.BackgroundTransparency = 0.2
    Instance.new("UICorner", frame)
    Instance.new("UIStroke", frame).Color = HUB_COLOR

    local input = Instance.new("TextBox", frame)
    input.Size = UDim2.new(0.9, 0, 0, 50)
    input.Position = UDim2.new(0.05, 0, 0.88, 0)
    input.PlaceholderText = "[ID:MSG] ou Global"
    input.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    input.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", input)

    input.FocusLost:Connect(function(enter)
        if enter and input.Text ~= "" then
            local text = input.Text
            if string.find(text, ":") then
                local split = string.split(text, ":")
                kineticRequest("PUT", BASE_URL .. "private/" .. string.gsub(split[1], " ", "") .. ".json", {["msg"] = split[2]})
            else
                kineticRequest("PUT", BASE_URL .. "announcement.json", {["msg"] = text})
            end
            input.Text = ""
        end
    end)
end

