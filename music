local function FetchAndLoop()
    -- 你的專屬 Firebase 連結
    local FIREBASE_URL = "https://e5alr9-default-rtdb.asia-southeast1.firebasedatabase.app/.json"
    
    local currentExecID = os.clock()
    _G.E5_Latest_ExecID = currentExecID
    
    local addedFiles = {}
    
    -- 初始化已存在的歌曲
    for _, s in ipairs(SongLibrary) do 
        addedFiles[s.File:lower()] = true 
    end

    task.spawn(function()
        while _G.E5_Music_Instance and _G.E5_Latest_ExecID == currentExecID do
            print("☁️ Firebase loading...")

            local success, result = pcall(function()
                return game:HttpGet(FIREBASE_URL)
            end)

            if success and result and result ~= "null" then
                local data = HttpService:JSONDecode(result)
                local foundNew = false
                
                -- 開始解析 Firebase 陣列
                for _, item in pairs(data) do
                    if item.name and item.download_url then
                        local fileID = item.name:lower()
                        
                        if not addedFiles[fileID] then
                            addedFiles[fileID] = true
                            foundNew = true
                            
                            -- 1. 移除副檔名 2. 處理 URL 編碼(%20) 3. 去掉括號內容
                            local cleanName = item.name:gsub("%.mp3$", "")
                            cleanName = cleanName:gsub("%%20", " ")
                            cleanName = cleanName:gsub("%(.-%)", "") -- 移除 (Lyrics) 等括號
                            cleanName = cleanName:gsub("[%-_]", " ") -- 將底線轉為空格
                            
                            table.insert(SongLibrary, {
                                Name = cleanName:upper(),
                                File = item.name,
                                URL = item.download_url
                            })
                            print("🎵 add: " .. cleanName:upper())
                        end
                    end
                end
                
                if foundNew then
                    -- 按字母排序
                    table.sort(SongLibrary, function(a, b) return a.Name < b.Name end)
                    
                    -- 刷新 UI
                    RefreshUIList()
                    
                    -- 更新滾動區域大小 (假設你的列表容器叫 ListPage)
                    if ListPage then
                        ListPage.CanvasSize = UDim2.new(0, 0, 0, #SongLibrary * 55)
                    end
                end
            else
                warn("☁️ Firebase error")
            end
            
            -- 每 30 秒自動檢查一次
            task.wait(30)
        end
    end)
end

