local function playSong(idx)
    -- 1. 狀態鎖定與索引計算
    if isSwitching or #SongLibrary == 0 then return end
    isSwitching = true
    
    idx = (idx - 1) % #SongLibrary + 1
    currentSongIndex = idx
    local d = SongLibrary[idx]

    -- 2. 立即停止並清除舊聲音，防止重疊
    if activeSound then
        activeSound:Stop()
        activeSound:Destroy()
        activeSound = nil
    end

    -- ------------------------------------------------------
    -- ⚡ [優化邏輯] 優先檢查本地檔案
    -- ------------------------------------------------------
    if isfile(d.File) then
        -- 檔案已存在，直接本地播放
        local sound = Instance.new("Sound")
        sound.Name = "E5_Music_Source"
        sound.SoundId = getcustomasset(d.File)
        sound.Volume = _G.E5_Volume
        sound.Looped = _G.E5_Looping
        sound:SetAttribute("SongName", d.Name:upper())
        sound:SetAttribute("SongIndex", idx)
        sound.Parent = SoundService
        
        -- 等待加載確保 TimeLength 正常
        if not sound.IsLoaded then sound.Loaded:Wait() end
        
        activeSound = sound
        activeSound:Play()
        SongNameLabel.Text = d.Name:upper()
        isSwitching = false -- 直接解鎖
        return -- 結束函數，不執行後面的下載邏輯
    end
    -- ------------------------------------------------------

    -- 3. 若檔案不存在，才進入下載流程
    SongNameLabel.Text = "DOWNLOADING..."
    
    task.spawn(function()
        print("📥 Downloading: " .. d.Name)
        local getSuccess, content = pcall(function() 
            return game:HttpGet(d.URL) 
        end)
        
        if not (getSuccess and content) then
            warn("❌ Download Failed: " .. d.Name)
            SongNameLabel.Text = "DOWNLOAD ERROR"
            isSwitching = false
            return
        end
        
        writefile(d.File, content)
        
        -- 下載完成後加載
        local loadSuccess, err = pcall(function()
            local sound = Instance.new("Sound")
            sound.Name = "E5_Music_Source"
            sound.SoundId = getcustomasset(d.File)
            sound.Volume = _G.E5_Volume
            sound.Looped = _G.E5_Looping
            sound:SetAttribute("SongName", d.Name:upper())
            sound:SetAttribute("SongIndex", idx)
            sound.Parent = SoundService
            
            if not sound.IsLoaded then sound.Loaded:Wait() end
            
            activeSound = sound 
            activeSound:Play()
        end)

        if loadSuccess then
            SongNameLabel.Text = d.Name:upper()
        else
            warn("❌ Playback Error: " .. tostring(err))
            SongNameLabel.Text = "PLAY ERROR"
        end
        
        isSwitching = false
    end)
end

