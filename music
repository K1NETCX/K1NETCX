-- 滾動邏輯函數
local function updateScroll()
    local TS = game:GetService("TweenService")
    -- 先停止並重置位置
    SongNameLabel.Position = UDim2.new(0, 0, 0, 0)
    task.wait(1.5) -- 換歌後稍微停頓一下再開始滾動
    
    local textWidth = SongNameLabel.TextBounds.X
    local maskWidth = SongNameMask.AbsoluteSize.X
    
    if textWidth > maskWidth then
        local scrollDistance = textWidth - maskWidth + 30
        local duration = scrollDistance / 25 -- 調整分母可改變滾動速度
        
        local info = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, true)
        local tween = TS:Create(SongNameLabel, info, {Position = UDim2.new(0, -scrollDistance, 0, 0)})
        tween:Play()
    end
end

