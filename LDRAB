local function create(data)
    local parent = workspace
    if data.PName then 
        parent = workspace:FindFirstChild(data.PName) or Instance.new('Folder', workspace)
        parent.Name = data.PName
    end
    local part = Instance.new(data.ClassName)
    if data.ClassName == 'Part' and data.Shape then part.Shape = Enum.PartType[data.Shape] end
    if data.ClassName == 'MeshPart' then part.MeshId = data.MID end
    part.Name = data.Name; part.CFrame = CFrame.new(unpack(data.CF)); part.Size = Vector3.new(unpack(data.SZ))
    part.Color = Color3.new(unpack(data.CL)); part.Material = Enum.Material[data.MT]
    part.Transparency = data.TR or 0; part.CanCollide = data.CC; part.Anchored = true; part.Parent = parent
    if data.Tex then
        for _, t in ipairs(data.Tex) do
            local tex = Instance.new(t.Type, part)
            tex.Texture = t.ID; tex.Face = Enum.NormalId[t.Face]; tex.Transparency = t.TR or 0
            if t.Type == 'Texture' then tex.StudsPerTileU = t.SU; tex.StudsPerTileV = t.SV end
        end
    end
end

