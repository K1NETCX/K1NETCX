    ['GeographicLatitude'] = 0,
    ['ExposureCompensation'] = 0.20000000298023224,
}

local function applyObjects() -- Criar/Atualizar Objetos e Nuvens
    -- Configuração das Nuvens (Localizadas no Terrain)
    local Clouds = T:FindFirstChildOfClass('Clouds') or Instance.new('Clouds', T)
    Clouds.Cover = 0.65
    Clouds.Density = 0.4
    Clouds.Color = Color3.fromRGB(61, 61, 61)

    -- Skybox e Efeitos
    local Sky = L:FindFirstChildOfClass('Sky') or Instance.new('Sky', L)
    Sky.SkyboxBk = 'http://www.roblox.com/asset/?id=144933338'
    Sky.SkyboxDn = 'http://www.roblox.com/asset/?id=144931530'
    Sky.SkyboxFt = 'http://www.roblox.com/asset/?id=144933262'
    Sky.SkyboxLf = 'http://www.roblox.com/asset/?id=144933244'
    Sky.SkyboxRt = 'http://www.roblox.com/asset/?id=144933299'
    Sky.SkyboxUp = 'http://www.roblox.com/asset/?id=144931564'
    Sky.SunTextureId = 'rbxasset://sky/sun.jpg'
    Sky.MoonTextureId = 'rbxasset://sky/moon.jpg'

    local SunRaysEffect = L:FindFirstChildOfClass('SunRaysEffect') or Instance.new('SunRaysEffect', L)
    SunRaysEffect.Intensity = 0.02500000037252903

    local BloomEffect = L:FindFirstChildOfClass('BloomEffect') or Instance.new('BloomEffect', L)
    BloomEffect.Size = 24
    BloomEffect.Intensity = 1

    local Atmosphere = L:FindFirstChildOfClass('Atmosphere') or Instance.new('Atmosphere', L)
    Atmosphere.Density = 0.30000001192092896
    Atmosphere.Offset = 0.25
    Atmosphere.Color = Color3.fromRGB(94, 159, 199)

    local ColorCorrection = L:FindFirstChildOfClass('ColorCorrectionEffect') or Instance.new('ColorCorrectionEffect', L)
    ColorCorrection.Contrast = 0.07999999821186066
    ColorCorrection.Brightness = 0
    ColorCorrection.Saturation = 0.07999999821186066
end

local function forceLighting()
    for prop, val in pairs(settings) do
        L[prop] = val
    end
    applyObjects()
end

-- Execução Inicial
forceLighting()

