-- Lógica de carregamento e teleporte inicial
local function loadBhop()
    local success, model = pcall(function() return game:GetObjects("rbxassetid://" .. ASSET_ID)[1] end)
    if success and model then
        model.Parent = workspace
        configurarMapaShibuya()
        task.wait(0.5)
        -- O teleporte para o DESTINO_FINAL foi removido daqui para priorizar o Hidrante definido na configuração do mapa
        root.Anchored = false
    else
        root.Anchored = false
    end
end

UIS.InputBegan:Connect(function(i, g) 
    if not g and i.KeyCode == Enum.KeyCode.J then 
        root.AssemblyLinearVelocity = Vector3.new(0,0,0)
        root.CFrame = DESTINO_FINAL 
    end 
end)

root.Anchored = true
root.CFrame = CFrame.new(root.Position.X, ALTURA_INICIAL, root.Position.Z)
task.wait(COOLDOWN)
loadBhop()
