-- Função para carregar os Assets do seu novo script
local function carregarAssetsExtras()
    for _, data in ipairs(assetsToLoad) do
        local success, objects = pcall(function()
            return game:GetObjects("rbxassetid://" .. data.id)
        end)

        if success and objects and objects[1] then
            local obj = objects[1]
            obj.Name = data.name
            obj.Parent = game.Workspace
            
            if data.size then
                if obj:IsA("BasePart") then
                    obj.Size = data.size
                elseif obj:IsA("Model") and obj.PrimaryPart then
                    obj.PrimaryPart.Size = data.size
                end
            end

            if obj:IsA("Model") then
                obj:PivotTo(data.cf)
                for _, p in ipairs(obj:GetDescendants()) do
                    if p:IsA("BasePart") then p.Anchored = true end
                end
            elseif obj:IsA("BasePart") then
                obj.CFrame = data.cf
                obj.Anchored = true
            end
        end
    end
end

-- Função principal de configuração do Mapa
local function configurarMapaShibuya()
    local shibuya = workspace:FindFirstChild("nn_Shibuya")
    if shibuya then
        local children = shibuya:GetChildren()

        -- 1. Desativar Colisões
        local targets = {
            children[243] and children[243]:FindFirstChild("Meshes/rooftop"),
            children[243] and children[243]:FindFirstChild("MeshPart"),
            children[230] and children[230]:FindFirstChild("Meshes/rooftop"),
            children[230] and children[230]:FindFirstChild("MeshPart"),
            children[229] and children[229]:FindFirstChild("Meshes/rooftop"),
            children[229] and children[229]:FindFirstChild("MeshPart"),
            children[1356]
        }

        for _, obj in pairs(targets) do
            if obj and obj:IsA("BasePart") then obj.CanCollide = false end
        end

        local structure = shibuya:FindFirstChild("Assets") and shibuya.Assets:FindFirstChild("Assets") and shibuya.Assets.Assets:FindFirstChild("Structure'")
        if structure then
            local sChildren = structure:GetChildren()
            if sChildren[20] and sChildren[20]:IsA("BasePart") then sChildren[20].CanCollide = false end
            local tank = structure:FindFirstChild("Cooling Tank")
            if tank and tank:IsA("BasePart") then tank.CanCollide = false end
