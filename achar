-- RUN LOOP
RunService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end

    if BhopActive and spacePressed then
        if humanoid.Health > 0 and humanoid.FloorMaterial ~= Enum.Material.Air then
            humanoid.Jump = true
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    if TASActive then
        local moveDir = humanoid.MoveDirection
        local is_g = chk_grnd(root)
        if moveDir.Magnitude > 0 then
            if not is_g then
                was_air = true
                cur_spd = math.min(max_air_spd, cur_spd + air_accel)
            else
                if was_air then
                    cur_spd = math.max(base_spd, cur_spd - ground_friction)
                    was_air = false
                end
                cur_spd = math.max(base_spd, cur_spd)
            end
            root.AssemblyLinearVelocity = Vector3.new(moveDir.X * cur_spd, root.AssemblyLinearVelocity.Y, moveDir.Z * cur_spd)
        else
            cur_spd = base_spd
            was_air = false
        end
    end

    if BounceActive then
        local currentVel = root.AssemblyLinearVelocity
        local verticalVel = currentVel.Y
        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping then
            horizontalMomentum = Vector3.new(currentVel.X, 0, currentVel.Z)
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {char}
            params.FilterType = Enum.RaycastFilterType.Exclude
            local hit = workspace:Raycast(root.Position, Vector3.new(0, -5, 0), params)
            if hit and verticalVel < -5 then
                if hit.Normal.Y < 0.95 then
                    local newJump = math.abs(verticalVel) * 1.05
                    root.AssemblyLinearVelocity = horizontalMomentum + Vector3.new(0, newJump, 0)
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.spawn(function()
                        humanoid.PlatformStand = true
                        task.wait(0.1)
                        humanoid.PlatformStand = false
                    end)
                end
            end
        end
    end

    if DownedActive then
        if char:GetAttribute("State") == "Downed" then
            local TARGET_BOOST = 1600
            local MAX_SPEED_CAP = 4750
            local VEL_SCALE = 90
            local SLOPE_ACCEL_FORCE = 6875
            local STRAFE_BOOST_MAX = 750
            local STRAFE_SENSITIVITY = 1.0
            local ACCEL_RATE = 450
            local FRICTION_DECAY = 0.9975
            local isCtrlHeld = UIS:IsKeyDown(Enum.KeyCode.LeftControl)
            if isCtrlHeld then
                if currentSpeed < TARGET_BOOST then
                    currentSpeed = math.min(currentSpeed + (ACCEL_RATE * dt * 5), TARGET_BOOST)
                end
            end
            local _, camYaw, _ = workspace.CurrentCamera.CFrame:ToEulerAnglesYXZ()
            local yawDelta = math.abs(camYaw - lastCameraYaw)
            if yawDelta > math.pi then yawDelta = math.abs(yawDelta - (math.pi * 2)) end
            local angularVelocity = yawDelta / dt
            local strafeBonus = math.min(angularVelocity * STRAFE_SENSITIVITY, STRAFE_BOOST_MAX)
            lastCameraYaw = camYaw
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {char}
            local ray = workspace:Raycast(root.Position, Vector3.new(0, -10, 0), rayParams)
            local slopeBonus = 0
            if ray and ray.Instance then
                local localNormal = root.CFrame:VectorToObjectSpace(ray.Normal)
                local rawSlope = -localNormal.Z
                if rawSlope > 0 then slopeBonus = rawSlope * SLOPE_ACCEL_FORCE * dt end
            end
            if slopeBonus > 0 then
                currentSpeed = math.min(currentSpeed + slopeBonus, MAX_SPEED_CAP)
            elseif isCtrlHeld or (angularVelocity > 1.5 and currentSpeed > 400) then
                currentSpeed = math.min(currentSpeed + (strafeBonus * dt), MAX_SPEED_CAP)
                currentSpeed = currentSpeed * 0.9995
            else
                if currentSpeed > 5 then currentSpeed = currentSpeed * FRICTION_DECAY else currentSpeed = 0 end
            end
            if currentSpeed > 0 then
                local studsPerSec = currentSpeed / VEL_SCALE
                local camLook = workspace.CurrentCamera.CFrame.LookVector
                local forwardDir = Vector3.new(camLook.X, 0, camLook.Z).Unit
                local horizontalMove = forwardDir * studsPerSec * dt
                root.CFrame = CFrame.new(root.Position.X + horizontalMove.X, root.Position.Y, root.Position.Z + horizontalMove.Z) * root.CFrame.Rotation
                char:SetAttribute("RelativeSpeed", currentSpeed)
            end
        else
            currentSpeed = 0
        end
    end
end)

