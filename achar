-- VIEWMODEL RENDER LOOP
local function grudarNaCamera(dt)
    if not viewmodelActive then
        if modeloAtual then modeloAtual:Destroy() modeloAtual = nil end
        return
    end
    if not modeloAtual then return end
    local camera = workspace.CurrentCamera
    local camCF = camera.CFrame
    local finalCF = camCF * CFrame.new(animacaoKarambit.lateralAtual, animacaoKarambit.alturaAtualInsp, -animacaoKarambit.distanciaAtual)
    finalCF = finalCF * CFrame.Angles(animacaoKarambit.rotacaoX, animacaoKarambit.rotacaoY, animacaoKarambit.rotacaoZ)
    if modeloAtual:IsA("Model") and modeloAtual.PrimaryPart then
        modeloAtual:SetPrimaryPartCFrame(finalCF)
    elseif modeloAtual:IsA("BasePart") then
        modeloAtual.CFrame = finalCF
    end
end

RunService.RenderStepped:Connect(grudarNaCamera)

