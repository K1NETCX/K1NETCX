local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer
local pGui = lp:WaitForChild("PlayerGui")

-- [[ CONFIGURAÇÃO DE FOV ]]
local FORCED_FOV = 70

-- [[ CRIAÇÃO DA UI ]]
if pGui:FindFirstChild("FOV_System") then pGui.FOV_System:Destroy() end
local sg = Instance.new("ScreenGui", pGui); sg.Name = "FOV_System"; sg.ResetOnSpawn = false

local Main = Instance.new("Frame", sg)
Main.Size = UDim2.new(0, 300, 0, 130)
Main.Position = UDim2.new(0.5, -150, 0.5, -65)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
Main.Active = true; Main.Draggable = true
Instance.new("UICorner", Main)
local Stroke = Instance.new("UIStroke", Main); Stroke.Color = Color3.fromHex("D656FF"); Stroke.Thickness = 2

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 45); Title.BackgroundTransparency = 1
Title.Text = "FIELD OF VIEW"; Title.TextColor3 = Color3.new(1, 1, 1)
Title.Font = Enum.Font.GothamBold; Title.TextSize = 16

-- [[ LÓGICA DO SLIDER ]]
local SliderBG = Instance.new("TextButton", Main)
SliderBG.Size = UDim2.new(0.85, 0, 0, 8); SliderBG.Position = UDim2.new(0.075, 0, 0.5, 0)
SliderBG.BackgroundColor3 = Color3.fromRGB(40, 40, 45); SliderBG.Text = ""
Instance.new("UICorner", SliderBG)

local SliderFill = Instance.new("Frame", SliderBG)
SliderFill.Size = UDim2.new(0.2, 0, 1, 0); SliderFill.BackgroundColor3 = Color3.fromHex("D656FF")
Instance.new("UICorner", SliderFill)

local ValueDisplay = Instance.new("TextLabel", Main)
ValueDisplay.Size = UDim2.new(1, 0, 0, 30); ValueDisplay.Position = UDim2.new(0, 0, 0.65, 0)
ValueDisplay.BackgroundTransparency = 1; ValueDisplay.TextColor3 = Color3.fromHex("D656FF")
ValueDisplay.Text = "FOV: 70"; ValueDisplay.Font = Enum.Font.Code; ValueDisplay.TextSize = 14

-- [[ FUNÇÕES DE FORÇAR FOV ]]
local function forceFOV()
    local camera = workspace.CurrentCamera
    if camera and camera.FieldOfView ~= FORCED_FOV then
        camera.FieldOfView = FORCED_FOV
    end
end

RunService.RenderStepped:Connect(forceFOV)
workspace.CurrentCamera:GetPropertyChangedSignal("FieldOfView"):Connect(forceFOV)

lp.CharacterAdded:Connect(function()
    task.wait(0.4)
    forceFOV()
end)

-- [[ INTERAÇÃO DO MOUSE ]]
local dragging = false
SliderBG.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

RunService.RenderStepped:Connect(function()
    if dragging then
        local mousePos = UIS:GetMouseLocation().X
        local relativePos = mousePos - SliderBG.AbsolutePosition.X
        local percentage = math.clamp(relativePos / SliderBG.AbsoluteSize.X, 0, 1)
        
        SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        FORCED_FOV = math.floor(50 + (percentage * 130)) -- Range de 50 a 180
        ValueDisplay.Text = "FOV: " .. tostring(FORCED_FOV)
    end
end)

-- [[ ABRIR / FECHAR (CTRL DIREITO) ]]
UIS.InputBegan:Connect(function(key, gameProcessed)
    if not gameProcessed and key.KeyCode == Enum.KeyCode.RightControl then
        Main.Visible = not Main.Visible
    end
end)

print("FOV GUI Carregada. Use CTRL DIREITO para abrir/fechar.")
